{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts.schemas.lifecycle-envelope.v1.json",
  "title": "Lifecycle Envelope v1",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "source_service", "experiment_id", "run_id"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "event_version": {
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "causation_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_service": {
      "type": "string",
      "minLength": 1
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
